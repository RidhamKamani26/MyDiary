<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:src="@drawable/bg_main_header"
        android:scaleType="centerCrop" />

    <!-- Title bar overlay on the image -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-200dp"
        android:paddingTop="40dp"
        android:paddingHorizontal="16dp"
        android:text="@string/set_password"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center" />

    <ImageView
        android:id="@+id/ibBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="-200dp"
        android:layout_marginStart="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/white" />

    <!-- White content card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="120dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="32dp"
        android:background="@drawable/bg_bottom_sheet_rounded">

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_password"
            android:textSize="16sp"
            android:textColor="@color/pink_primary"
            android:fontFamily="@font/poppins_semibold" />

        <!-- PIN dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/dot1"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/dot_empty" />

            <ImageView
                android:id="@+id/dot2"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/dot_empty" />

            <ImageView
                android:id="@+id/dot3"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/dot_empty" />

            <ImageView
                android:id="@+id/dot4"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="20dp"
                android:src="@drawable/dot_empty" />

        </LinearLayout>

        <!-- Number grid -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:columnCount="3"
            android:rowCount="4">

            <TextView android:id="@+id/btn1" android:text="1" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn2" android:text="2" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn3" android:text="3" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn4" android:text="4" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn5" android:text="5" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn6" android:text="6" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn7" android:text="7" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn8" android:text="8" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn9" android:text="9" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <Space android:layout_width="72dp" android:layout_height="72dp" android:layout_columnWeight="1" />
            <TextView android:id="@+id/btn0" android:text="0" style="@style/PinKeyStyle" android:layout_columnWeight="1" />
            <ImageView android:id="@+id/btnBackspace" android:layout_width="72dp" android:layout_height="72dp" android:src="@drawable/ic_backspace" android:padding="20dp" android:background="?attr/selectableItemBackgroundBorderless" app:tint="@color/pink_primary" android:layout_columnWeight="1" />

        </GridLayout>

    </LinearLayout>

</LinearLayout>
