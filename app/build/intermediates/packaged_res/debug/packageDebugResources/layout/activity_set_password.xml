            &lt;!&ndash; 0 key &ndash;&gt;
            <TextView
                android:id="@+id/btn0"
                style="@style/PinKeyStyle"
                android:layout_marginHorizontal="20dp"
                android:text="0" />

            <TextView
                android:id="@+id/btn0"
                style="@style/PinKeyStyle"
                android:layout_marginHorizontal="20dp"
                android:text="0" />

            &lt;!&ndash; Backspace: pink rounded square with white X &ndash;&gt;
&lt;!&ndash;            <FrameLayout&ndash;&gt;
&lt;!&ndash;                android:id="@+id/btnBackspace"&ndash;&gt;
&lt;!&ndash;                android:layout_width="72dp"&ndash;&gt;
