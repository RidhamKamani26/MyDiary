<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/ibBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/vault_title"
            android:textSize="17sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center" />

        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="24dp"
        android:columnCount="2"
        android:rowCount="2"
        android:useDefaultMargins="true">

        <LinearLayout
            android:id="@+id/cardImages"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_vault_card">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_image"
                app:tint="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/images_title"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardVideos"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_vault_card">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_video"
                app:tint="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Videos"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAudios"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_vault_card">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_audio"
                app:tint="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Audios"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardSettings"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_vault_card">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_title"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/poppins_medium" />
        </LinearLayout>

    </GridLayout>

</LinearLayout>
