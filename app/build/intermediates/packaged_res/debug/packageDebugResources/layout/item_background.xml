<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="100dp" android:layout_height="80dp"
    android:layout_margin="4dp">
    <View android:id="@+id/vColorPreview" android:layout_width="match_parent"
        android:layout_height="match_parent" android:background="@drawable/bg_background_item" />
    <ImageView android:id="@+id/ivSelected" android:layout_width="20dp"
        android:layout_height="20dp" android:layout_gravity="bottom|end"
        android:layout_margin="4dp" android:src="@drawable/ic_check_circle"
        android:visibility="gone" />
</FrameLayout>
