<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp" android:elevation="2dp">
        <ImageView android:id="@+id/ibBack" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@drawable/ic_back" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/password_settings" android:textSize="17sp" android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold" android:gravity="center" />
        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/password_label" android:textSize="15sp"
            android:textColor="@color/pink_primary" android:fontFamily="@font/poppins_semibold" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/enable_disable" android:textSize="15sp" android:textColor="@color/text_primary" android:fontFamily="@font/poppins_medium" />
            <Switch android:id="@+id/switchEnablePassword" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:thumbTint="@color/pink_primary" android:trackTint="@color/pink_light" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color" />
        <LinearLayout android:id="@+id/llChangePassword" android:layout_width="match_parent"
            android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/change_password" android:textSize="15sp" android:textColor="@color/text_primary" android:fontFamily="@font/poppins_medium" />
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color" />
        <LinearLayout android:id="@+id/llForgotPassword" android:layout_width="match_parent"
            android:layout_height="52dp" android:orientation="horizontal" android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/forgot_password" android:textSize="15sp" android:textColor="@color/text_primary" android:fontFamily="@font/poppins_medium" />
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
