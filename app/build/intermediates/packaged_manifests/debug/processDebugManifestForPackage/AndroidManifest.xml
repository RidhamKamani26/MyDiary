<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mydiary.app"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <permission
        android:name="com.mydiary.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.mydiary.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.mydiary.app.MyDiaryApp"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.MyDiary" >

        <!-- Splash Screen -->
        <activity
            android:name="com.mydiary.app.activities.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.MyDiary.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding -->
        <activity
            android:name="com.mydiary.app.activities.OnboardingActivity"
            android:exported="false"
            android:noHistory="true" />

        <!-- Main -->
        <activity
            android:name="com.mydiary.app.activities.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Add/Edit Note -->
        <activity
            android:name="com.mydiary.app.activities.AddNoteActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Note Detail -->
        <activity
            android:name="com.mydiary.app.activities.NoteDetailActivity"
            android:exported="false" />

        <!-- Password Setup -->
        <activity
            android:name="com.mydiary.app.activities.SetPasswordActivity"
            android:exported="false" />

        <!-- Security Question -->
        <activity
            android:name="com.mydiary.app.activities.SecurityQuestionActivity"
            android:exported="false" />

        <!-- Private Vault -->
        <activity
            android:name="com.mydiary.app.activities.VaultActivity"
            android:exported="false" />

        <!-- Vault Images -->
        <!--
            <activity
            android:name=".activities.VaultSettingsActivity"
            android:exported="false" />
        -->


        <!-- Themes -->
        <activity
            android:name="com.mydiary.app.activities.ThemesActivity"
            android:exported="false" />

        <!-- Settings -->
        <activity
            android:name="com.mydiary.app.activities.SettingsActivity"
            android:exported="false" />

        <!-- Password Settings -->
        <activity
            android:name="com.mydiary.app.activities.PasswordSettingsActivity"
            android:exported="false" />

        <!-- Calendar -->
        <activity
            android:name="com.mydiary.app.activities.CalendarActivity"
            android:exported="false" />

        <!-- Vault Media -->
        <activity
            android:name="com.mydiary.app.activities.VaultMediaActivity"
            android:exported="false" />
        <activity
            android:name="com.mydiary.app.activities.SplashCoverActivity"
            android:exported="false"
            android:noHistory="true" />
        <activity
            android:name="com.mydiary.app.activities.VaultSettingsActivity"
            android:exported="false" />
        <activity
            android:name="com.mydiary.app.activities.ForgotPasswordActivity"
            android:exported="false" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.mydiary.app.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>