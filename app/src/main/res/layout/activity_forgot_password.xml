<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/white" android:paddingHorizontal="20dp" android:paddingTop="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical">
        <ImageView android:id="@+id/ibBack" android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" android:src="@drawable/ic_back" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/forgot_password" android:textSize="17sp" android:textColor="@color/text_primary"
            android:fontFamily="@font/poppins_semibold" android:gravity="center" />
        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>
    <TextView android:id="@+id/tvQuestion" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="24dp"
        android:textSize="16sp" android:textColor="@color/text_primary" android:fontFamily="@font/poppins_semibold" />
    <EditText android:id="@+id/etAnswer" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="16dp"
        android:hint="Enter your answer" android:textColorHint="@color/text_hint"
        android:background="@drawable/bg_input_field" android:paddingHorizontal="16dp" android:paddingVertical="14dp"
        android:inputType="textCapWords" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnVerify"
        style="@style/Widget.MyDiary.Button.Pink" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="Verify" />
</LinearLayout>
