<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- PIN numpad key: light pink 72×72 rounded square, pink number -->
    <style name="PinKeyStyle">
        <item name="android:layout_width">62dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#FF4081</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_pin_key_normal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

</resources>
